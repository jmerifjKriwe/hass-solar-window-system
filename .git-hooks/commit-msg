#!/usr/bin/env bash
# Commit message hook to validate Conventional Commits format

# Get commit message from file
commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Allow merge commits to pass validation
# Merge commits typically start with "Merge branch", "Merge pull request", etc.
commit_subject=$(echo "$commit_msg" | head -n 1)
if [[ $commit_subject =~ ^Merge[[:space:]] ]]; then
    exit 0
fi

# Regular expression for Conventional Commits
# Format: type(scope): description or type!(scope): description for breaking changes
# Types: feat, fix, docs, style, refactor, perf, test, chore, ci, revert, build
# IMPORTANT: Must match release-please parser expectations
conventional_commit_regex="^(feat|fix|docs|style|refactor|perf|test|chore|ci|revert|build)(\([a-zA-Z0-9_-]+\))?!?: .+"

# Valid types
valid_types="feat|fix|docs|style|refactor|perf|test|chore|ci|revert|build"

# Check if commit message matches Conventional Commits format
# Only check the first line (subject), ignore body for validation
commit_subject=$(echo "$commit_msg" | head -n 1)
if [[ ! $commit_subject =~ $conventional_commit_regex ]]; then
    echo "❌ Invalid commit message format!"
    echo ""
    echo "Commit messages must follow the Conventional Commits format:"
    echo "  type(scope): description"
    echo ""
    echo "Valid types: feat, fix, docs, style, refactor, perf, test, chore, ci, revert, build"
    echo ""
    echo "Examples:"
    echo "  feat(coordinator): add diffuse radiation estimation"
    echo "  fix(sensor): resolve device info missing"
    echo "  docs(readme): update installation instructions"
    echo "  ci(workflow): upgrade to python 3.14"
    echo ""
    echo "See COMMIT_CONVENTIONS.md for more details."
    exit 1
fi

# Extract type from commit message (first line only)
# Handles both normal (type:) and breaking change (type!:) formats
type=$(echo "$commit_subject" | sed -E "s/^([a-z]+)(\([a-zA-Z0-9_-]+\))?[!]?: .+/\1/")

# Check if type is valid
if [[ ! $type =~ ^($valid_types)$ ]]; then
    echo "❌ Invalid commit type: '$type'"
    echo ""
    echo "Valid types: feat, fix, docs, style, refactor, perf, test, chore, ci, revert, build"
    echo ""
    echo "See COMMIT_CONVENTIONS.md for more details."
    exit 1
fi

# Check minimum description length (after type, scope, and optional breaking change marker)
description=$(echo "$commit_subject" | sed -E "s/^[a-z]+(\([a-zA-Z0-9_-]+\))?[!]?: //")
if [[ ${#description} -lt 3 ]]; then
    echo "❌ Commit description too short (minimum 3 characters)"
    echo ""
    echo "Example: feat(coordinator): add diffuse radiation estimation"
    echo ""
    echo "See COMMIT_CONVENTIONS.md for more details."
    exit 1
fi

# Success
exit 0
